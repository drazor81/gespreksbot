{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "..",
    "resolveJsonModule": true,
    "noEmit": true
  },
  "include": [
    "./**/*.ts",
    "../src/shared/**/*.ts",
    "../src/config.ts",
    "../src/types.ts",
    "../src/knowledge/**/*.ts",
    "../personas.json"
  ]
}
